body {
    font-family: Arial, sans-serif;
    width: 80%;
    margin: auto;
}


h1 {
    text-align: center;
}


.search-box {
    text-align: center;
    margin: 30px;
}


input {
    width: 300px;
    padding: 10px;
}


button {
    padding: 10px 15px;
    cursor: pointer;
}


.movie-card {
    border: 1px solid #ddd;
    padding: 15px;
    margin: 15px;
    display: flex;
    gap: 20px;
}


.movie-card img {
    width: 150px;
}


.favorite {
    background-color: pink;
}
